from datetime import datetime

class Contact:
    """Represents a single JAWG contact."""
    def __init__(self, name, organization, role, email, connection):
        self.name = name
        self.organization = organization
        self.role = role
        self.email = email
        self.connection = connection

    def to_dict(self):
        """Return the contact information as a dictionary."""
        return {
            "Name": self.name,
            "Organization": self.organization,
            "Role": self.role,
            "Email": self.email,
            "Connection": self.connection
        }

    def display(self):
        """Print the contact information using string formatting."""
        info = self.to_dict()
        print()
        for key, value in info.items():
            print(f"{key}: {value}")


